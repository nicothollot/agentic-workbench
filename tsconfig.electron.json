{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "baseUrl": ".",
    "paths": {
      "@main/*": ["src/main/*"],
      "@preload/*": ["src/preload/*"],
      "@renderer/*": ["src/renderer/*"],
      "@runtime/*": ["src/runtime/*"],
      "@shared/*": ["src/shared/*"],
      "@generated/*": ["src/generated/*"]
    },
    "lib": ["ES2023"],
    "types": ["node"]
  },
  "include": [
    "src/main/**/*.ts",
    "src/preload/**/*.ts",
    "src/runtime/**/*.ts",
    "src/shared/**/*.ts",
    "src/generated/**/*.ts",
    "vite.main.config.ts",
    "vite.preload.config.ts"
  ]
}
